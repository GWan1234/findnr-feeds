# 默认所有文件使用 LF
* text=auto eol=lf

# Shell 脚本和配置文件强制 LF
*.sh text eol=lf
*.lua text eol=lf
*.htm text eol=lf
*.js text eol=lf
*.json text eol=lf
*.po text eol=lf
*.pot text eol=lf
*.ut text eol=lf
Makefile text eol=lf

# OpenWrt 特殊文件强制 LF（无扩展名的脚本）
root/etc/init.d/* text eol=lf
root/etc/uci-defaults/* text eol=lf
root/etc/config/* text eol=lf
root/usr/share/luci-app-*/luci text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.ico binary
